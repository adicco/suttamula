{
  "an2.87:0.1": "The Numerical Discourses 2",
  "an2.87:0.2": "9. The Dhamma Chapter",
  "an2.87:1.0": "87",
  "an2.87:1.1": "\"There are these two *dhammas*, *bhikkhus*.",
  "an2.87:1.2": "What two?",
  "an2.87:1.3": "Liberation of mind [*citta*] and liberation through discernment [*paññā*].",
  "an2.87:1.4": "These are the two *dhammas*.\"",
  "an2.88:1.0": "88",
  "an2.88:1.1": "\"There are these two *dhammas*, *bhikkhus*.",
  "an2.88:1.2": "What two?",
  "an2.88:1.3": "Effort and non-distraction.",
  "an2.88:1.4": "These are the two *dhammas*.\"",
  "an2.89:1.0": "89",
  "an2.89:1.1": "\"There are these two *dhammas*, *bhikkhus*.",
  "an2.89:1.2": "What two?",
  "an2.89:1.3": "*nāma* and *rūpa*.",
  "an2.89:1.4": "These are the two *dhammas*.\"",
  "an2.90:1.0": "90",
  "an2.90:1.1": "\"There are these two *dhammas*, *bhikkhus*.",
  "an2.90:1.2": "What two?",
  "an2.90:1.3": "True knowledge and liberation.",
  "an2.90:1.4": "These are the two *dhammas*.\"",
  "an2.91:1.0": "91",
  "an2.91:1.1": "\"There are these two *dhammas*, *bhikkhus*.",
  "an2.91:1.2": "What two?",
  "an2.91:1.3": "The view of existence and the view of non-existence.",
  "an2.91:1.4": "These are the two *dhammas*.\"",
  "an2.92:1.0": "92",
  "an2.92:1.1": "\"There are these two *dhammas*, *bhikkhus*.",
  "an2.92:1.2": "What two?",
  "an2.92:1.3": "Shamelessness and recklessness.",
  "an2.92:1.4": "These are the two *dhammas*.\"",
  "an2.93:1.0": "93",
  "an2.93:1.1": "\"There are these two *dhammas*, *bhikkhus*.",
  "an2.93:1.2": "What two?",
  "an2.93:1.3": "Shame and dread.",
  "an2.93:1.4": "These are the two *dhammas*.\"",
  "an2.94:1.0": "94",
  "an2.94:1.1": "\"There are these two *dhammas*, *bhikkhus*.",
  "an2.94:1.2": "What two?",
  "an2.94:1.3": "Being difficult to admonish and bad companionship.",
  "an2.94:1.4": "These are the two *dhammas*.\"",
  "an2.95:1.0": "95",
  "an2.95:1.1": "\"There are these two *dhammas*, *bhikkhus*.",
  "an2.95:1.2": "What two?",
  "an2.95:1.3": "Being easy to admonish and good companionship.",
  "an2.95:1.4": "These are the two *dhammas*.\"",
  "an2.96:1.0": "96",
  "an2.96:1.1": "\"There are these two *dhammas*, *bhikkhus*.",
  "an2.96:1.2": "What two?",
  "an2.96:1.3": "Proficiency in the elements and proficiency in attention.",
  "an2.96:1.4": "These are the two *dhammas*.\"",
  "an2.97:1.0": "97",
  "an2.97:1.1": "\"There are these two *dhammas*, *bhikkhus*.",
  "an2.97:1.2": "What two?",
  "an2.97:1.3": "Proficiency in offenses and proficiency in emerging from offenses.",
  "an2.97:1.4": "These are the two *dhammas*.\"",
  "an2.97:1.5": "The Dhamma Chapter, the fourth."
}
