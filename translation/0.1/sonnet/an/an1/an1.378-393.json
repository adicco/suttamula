{
  "an1.378:0.1": "The Numerical Discourses 1 ",
  "an1.378:0.2": "28. The Chapter on Qualities That Inspire Confidence ",
  "an1.378:1.1": "\"This, *bhikkhus*, is a boon for gains — namely, being a forest-dweller …",
  "an1.379:1.1": "being an alms-food-eater …",
  "an1.380:1.1": "being a rag-robe-wearer …",
  "an1.381:1.1": "being a three-robe-wearer …",
  "an1.382:1.1": "being a *dhamma* speaker …",
  "an1.383:1.1": "being a holder of the *vinaya* …",
  "an1.384:1.1": "being widely learned …",
  "an1.385:1.1": "being steadfast …",
  "an1.386:1.1": "having accomplished deportment …",
  "an1.387:1.1": "having accomplished a following …",
  "an1.388:1.1": "having a large following …",
  "an1.389:1.1": "being of noble birth …",
  "an1.390:1.1": "having a handsome appearance …",
  "an1.391:1.1": "having beautiful speech …",
  "an1.392:1.1": "having few wishes …",
  "an1.393:1.1": "having few ailments.\"",
  "an1.393:1.2": "(Sixteen qualities that inspire confidence, concluded.)"
}
