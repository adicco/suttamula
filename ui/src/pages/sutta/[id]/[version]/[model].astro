---
import Base from '../../../../layouts/Base.astro';
import SuttaView from '../../../../components/SuttaView.astro';
import TermDialog from '../../../../components/TermDialog.astro';
import { getAllCombos, getLatestVersion, getSutta, resolveVersion, modelToSlug, slugToModel } from '../../../../lib/db';
import { renderEnglishWithTerms } from '../../../../lib/terms';

export function getStaticPaths() {
	const combos = getAllCombos();
	const latest = getLatestVersion();
	const paths = [];
	for (const c of combos) {
		const model = modelToSlug(c.model);
		paths.push({ params: { id: c.suttaId, version: c.version, model } });
		if (c.version === latest) paths.push({ params: { id: c.suttaId, version: 'latest', model } });
	}
	return paths;
}

const { id, version: urlVersion, model: modelSlug } = Astro.params;
const model = slugToModel(modelSlug!);
const realVersion = resolveVersion(urlVersion!);
const sutta = getSutta(id!);
const hasEn = !!sutta?.title_en?.trim();
const rawTitle = hasEn ? sutta!.title_en!.trim() : (sutta?.title_pali?.trim() || id!);
const plainTitle = rawTitle.replace(/[*[\]]/g, ''); // for the browser tab title
const titleHtml = renderEnglishWithTerms(rawTitle, new Set()); // italics, no interactivity
---
<Base title={plainTitle}>
	<p class="eyebrow">{sutta?.nikaya?.toUpperCase()} · {id}</p>
	<h1 class:list={[{ 'h1--pali': !hasEn }]} set:html={titleHtml} />
	<SuttaView suttaId={id!} version={realVersion} model={model!} urlVersion={urlVersion!} />
	<TermDialog />
</Base>

<style>
	.h1--pali { font-style: italic; opacity: 0.8; }
</style>
