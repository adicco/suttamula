---
import Base from '../layouts/Base.astro';
import SuttaList from '../components/SuttaList.astro';
import { getNikayas } from '../lib/db';

const NAMES: Record<string, string> = {
  sn: 'The Connected Discourses',
  mn: 'The Middle Length Discourses',
  an: 'The Numerical Discourses',
  ud: 'Inspired Utterances',
  dn: 'The Long Discourses',
};
const nikayas = getNikayas();
---
<Base title="Suttamūla — Pāli Canon Translations">
  <p class="eyebrow">Early Buddhism first · Public domain</p>
  <h1>Suttamūla</h1>
  <p class="lede">Fresh translations of the Buddhist Pāli Canon, returning to the root meaning
    of the early texts.</p>

  <div class="nikayas">
    {nikayas.map((n, i) => (
      <details class="nikaya" open={i === 0}>
        <summary class="nikaya__summary">
          <span class="nikaya__name">{NAMES[n.nikaya] ?? n.nikaya.toUpperCase()}</span>
          <span class="nikaya__abbr">{n.nikaya.toUpperCase()}</span>
          <span class="nikaya__count">{n.count} suttas</span>
        </summary>
        <div class="nikaya__body">
          <SuttaList nikaya={n.nikaya} />
        </div>
      </details>
    ))}
  </div>
</Base>

<style>
  .nikayas { margin-top: 2.5rem; border-top: 1px solid var(--sand); }
  .nikaya { border-bottom: 1px solid var(--sand); }
  .nikaya__summary {
    list-style: none; cursor: pointer; display: flex; align-items: baseline; gap: 0.6rem;
    padding: 1rem 0.25rem;
  }
  .nikaya__summary::-webkit-details-marker { display: none; }
  .nikaya__summary::before {
    content: '›'; font-family: var(--sans); color: var(--muted);
    transition: transform 0.15s; display: inline-block; width: 0.8rem;
  }
  .nikaya[open] > .nikaya__summary::before { transform: rotate(90deg); }
  .nikaya__name { font-family: var(--serif); font-size: 1.3rem; color: var(--ink); }
  .nikaya__abbr { font-family: var(--sans); font-size: 0.72rem; letter-spacing: 0.1em; color: var(--muted); }
  .nikaya__count { font-family: var(--sans); font-size: 0.78rem; color: var(--muted); margin-left: auto; }
  .nikaya__summary:hover .nikaya__name { color: var(--oxblood); }
  .nikaya__body { padding: 0 0.25rem 1.25rem 1.4rem; }
</style>
